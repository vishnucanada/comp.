# Anthropic API key — required for natural language policy translation via Claude
ANTHROPIC_API_KEY=your_key_here

# Dashboard API key — protects write endpoints. Leave unset to disable auth.
# API_KEY=your_api_key_here

# Dashboard allowed origins (comma-separated).
# Defaults to http://localhost:8000 if unset. Set for production deployments.
# ALLOWED_ORIGINS=http://localhost:8000,https://your-domain.com

# GDPR audit log HMAC key — optional, enables tamper-evident audit entries.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# GDPR_AUDIT_HMAC_KEY=your_hmac_key_here

# Admin audit log HMAC key — signs admin action log entries (policy saves, model loads, etc.)
# ADMIN_AUDIT_HMAC_KEY=your_hmac_key_here

# RBAC key map — JSON object mapping API keys to roles: admin, policy-editor, viewer
# Roles: admin (full access), policy-editor (write policies, no admin routes), viewer (read-only)
# RBAC_KEYS={"key-abc123":"admin","key-xyz456":"policy-editor","key-viewer":"viewer"}

# Multi-tenancy: pass X-Tenant-ID header per request to namespace policies/checkpoints/audit.
# No configuration needed — tenants are created automatically on first request.
