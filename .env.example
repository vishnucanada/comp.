# Anthropic API key — required for natural language policy translation via Claude
ANTHROPIC_API_KEY=your_key_here

# Dashboard allowed origins (comma-separated).
# Defaults to http://localhost:8000 if unset. Set for production deployments.
# ALLOWED_ORIGINS=http://localhost:8000,https://your-domain.com

# GDPR audit log HMAC key — optional, enables tamper-evident audit entries.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# GDPR_AUDIT_HMAC_KEY=your_hmac_key_here
