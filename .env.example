# --- LLM backends (used by the dashboard chat) ----------------------------
# Anthropic API key — enables Claude as a chat backend in the dashboard.
ANTHROPIC_API_KEY=your_key_here

# OpenAI API key — required for the OpenAI moderation guard (free of charge).
# OPENAI_API_KEY=your_key_here

# --- Dashboard auth -------------------------------------------------------
# Protects write endpoints. Leave unset to disable auth.
# API_KEY=your_api_key_here

# Dashboard allowed origins (comma-separated). Default: http://localhost:8000
# ALLOWED_ORIGINS=http://localhost:8000,https://your-domain.com

# --- Audit logs -----------------------------------------------------------
# Signs admin action log entries (policy saves, etc.)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ADMIN_AUDIT_HMAC_KEY=your_hmac_key_here
